# Variables d'environnement - backend FastAPI
# Sur OpenShift, ces valeurs sont injectées via un Secret

POSTGRES_HOST=postgresql          # Nom du service PostgreSQL dans OpenShift
POSTGRES_PORT=5432
POSTGRES_DB=clouddemo
POSTGRES_USER=clouddemo_user
POSTGRES_PASSWORD=motdepassesecret

# URL du frontend Vercel (pour le CORS)
FRONTEND_URL=https://votre-app.vercel.app
